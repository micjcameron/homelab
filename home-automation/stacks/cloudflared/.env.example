# Cloudflare Tunnel token — from the Zero Trust dashboard when you create the tunnel
# (Networks -> Tunnels -> create -> "Docker" gives you a token starting with eyJ...).
# Copy this file to .env on the Pi and paste the token. NEVER commit the real .env.
TUNNEL_TOKEN=PASTE_YOUR_CLOUDFLARE_TUNNEL_TOKEN_HERE

# --- cf-access.sh (Access email-gates for proxies) -------------------------
# API token with "Access: Apps and Policies = Edit" (Account scope).
# Create at dash.cloudflare.com -> My Profile -> API Tokens -> Create Token.
CF_API_TOKEN=PASTE_CLOUDFLARE_API_TOKEN_HERE
# Account ID: Cloudflare dashboard -> Account Home -> right sidebar (or any zone overview).
CF_ACCOUNT_ID=PASTE_CLOUDFLARE_ACCOUNT_ID_HERE
# Optional: how long a login lasts before re-auth (default 168h = 1 week).
# SESSION_DURATION=168h
