# Copy this file to `.env` (which is gitignored) and fill in real values.
#   cp personal-scripts/.env.example personal-scripts/.env
#
# Telegram bot tokens come from @BotFather. HA_TOKEN is a Home Assistant
# long-lived access token (HA → your profile → Security → Long-lived tokens).
# Both reminder scripts source this file at runtime.

# Telegram chat to send to (shared by both reminders)
TELEGRAM_CHAT_ID=000000000

# Bin-day reminder: its own bot + an HA token (reads the afvalbeheer calendar)
BIN_BOT_TOKEN=123456:replace-me
HA_TOKEN=replace-me

# Parent reminder: its own bot
PARENT_BOT_TOKEN=123456:replace-me
