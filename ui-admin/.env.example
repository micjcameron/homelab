# ui-admin — copy to .env and fill in. The container loads this via compose env_file;
# for local dev, put overrides in server/.env.local instead.

# ── HTTP ──────────────────────────────────────────────────────────────────────
PORT=8090
NODE_ENV=production

# ── Paths (inside the container the repo is mounted at /repo) ─────────────────
REPO_PATH=/repo
# STACKS_DIR / SERVICES_JSON / SCRIPTS_DIR default off REPO_PATH; override if needed.
HOST_FS_PATH=/host-home        # a host mount, for disk-usage reporting

# ── Auth (Phase 2) ────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME                 # plaintext (simplest) …
# ADMIN_PASSWORD_HASH=                    # …or a bcrypt hash (preferred); takes precedence
JWT_SECRET=CHANGE_ME_LONG_RANDOM_STRING
ACCESS_TOKEN_EXPIRY=12h
COOKIE_SECURE=false            # set true once only reached over HTTPS (Cloudflare)

# ── Telegram: admin/command bot (reuse lifeline bot) (Phase 3/4) ─────────────
TELEGRAM_MODE=polling                     # polling | webhook
TELEGRAM_BOT_TOKEN=PLACEHOLDER_LIFELINE_BOT_TOKEN
TELEGRAM_CHAT_ID=8588606286
TELEGRAM_WEBHOOK_SECRET=CHANGE_ME_WEBHOOK_SECRET

# ── Telegram: dedicated network-watch bot (Phase 6) ──────────────────────────
NETWATCH_BOT_TOKEN=PLACEHOLDER_NETWATCH_BOT_TOKEN
NETWATCH_WEBHOOK_SECRET=CHANGE_ME_NETWATCH_SECRET

# ── Home Assistant (Phase 5 scripts / HA calls) ──────────────────────────────
HA_URL=http://host.docker.internal:8123
HA_TOKEN=PLACEHOLDER_HA_LONG_LIVED_TOKEN

# ── Pi-hole (Phase 6 device discovery + blocking) ────────────────────────────
PIHOLE_URL=http://host.docker.internal
PIHOLE_PASSWORD=PLACEHOLDER_PIHOLE_APP_PASSWORD

# ── Postgres (Phase 6) ───────────────────────────────────────────────────────
DB_HOST=ui-admin-db
DB_PORT=5432
DB_USER=uiadmin
DB_PASSWORD=CHANGE_ME_DB_PASSWORD
DB_NAME=uiadmin
POSTGRES_USER=uiadmin
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
POSTGRES_DB=uiadmin
