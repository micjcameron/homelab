{
  "name": "ui-admin-server",
  "version": "1.0.0",
  "description": "Homelab admin backend (NestJS) — service control, telegram, device watch",
  "scripts": {
    "build": "nest build",
    "start": "node dist/main",
    "start:dev": "cross-env NODE_ENV=development nest start --watch",
    "start:local": "cross-env NODE_ENV=local nest start --watch",
    "start:stack:local": "docker compose -f docker-compose.dev.yml up -d db",
    "create-admin": "cross-env TS_NODE_TRANSPILE_ONLY=1 ts-node scripts/create-admin-user.ts",
    "create-admin:local": "cross-env NODE_ENV=local npm run create-admin",
    "db:reset": "cross-env TS_NODE_TRANSPILE_ONLY=1 ts-node scripts/reset-db.ts",
    "db:reset:local": "cross-env NODE_ENV=local npm run db:reset",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint": "eslint \"src/**/*.ts\""
  },
  "dependencies": {
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.6",
    "@nestjs/schedule": "^6.0.1",
    "@nestjs/serve-static": "^5.0.3",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/throttler": "^6.4.0",
    "@nestjs/typeorm": "^11.0.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.2.2",
    "nest-winston": "^1.10.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.26",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.10",
    "@nestjs/schematics": "^11.0.7",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.3",
    "@types/node": "^24.5.1",
    "@types/passport-jwt": "^4.0.1",
    "cross-env": "^10.0.0",
    "eslint": "^9.35.0",
    "prettier": "^3.6.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  }
}
